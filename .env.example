# Copy to .env and adjust. All variables are prefixed with OBS_.

# Logical service name reported to OpenTelemetry.
OBS_SERVICE_NAME=observability-platform
# Deployment environment label (dev | staging | prod).
OBS_ENV=dev
# Root log level (DEBUG | INFO | WARNING | ERROR).
OBS_LOG_LEVEL=INFO

# HTTP server bind address and port.
OBS_HOST=0.0.0.0
OBS_PORT=8000

# OTLP gRPC endpoint of the OpenTelemetry Collector.
OBS_OTLP_ENDPOINT=http://otel-collector:4317
# Port exposing the Prometheus scrape endpoint from the collector.
OBS_PROMETHEUS_PORT=9464
# Loki push API endpoint.
OBS_LOKI_ENDPOINT=http://loki:3100/loki/api/v1/push
# Tempo OTLP endpoint.
OBS_TEMPO_ENDPOINT=http://tempo:4317
